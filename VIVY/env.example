# DeepSeek API
DEEPSEEK_API_KEY=YOUR_API_KEY
# DeepSeek chat base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model name (adjust if needed)
DEEPSEEK_MODEL=deepseek-chat

# Flask
FLASK_PORT=5000

# Optional: enable LLM-based memory summary
LLM_SUMMARY=true

# =========================
# VIVY 语音输入 / 语音播报
# =========================

# 回复后自动播报
VIVY_AUTO_VOICE_REPLY=true

# 流式回复时，按句子边显示边播报
VIVY_STREAM_TTS=true

# Windows 语音识别（点 🎤语音 时使用）
VIVY_STT_TIMEOUT=8
# 中文 zh-CN / 日语 ja-JP
VIVY_STT_CULTURE=ja-JP

# =========================
# GPT-SoVITS TTS
# =========================

# system = Windows 系统音色
# gptsovits = 本地 GPT-SoVITS
VIVY_TTS_MODE=gptsovits

# 本地 GPT-SoVITS /tts 接口
VIVY_GSV_TTS_URL=http://127.0.0.1:9880/tts

# 回复文本语言
VIVY_GSV_TEXT_LANG=ja

# 参考音频路径
VIVY_GSV_REF_AUDIO=D:\path\to\your\reference.wav

# 参考音频对应原文
VIVY_GSV_PROMPT_TEXT=おさむさんがお友達をここに連れてくるのが先か

# 参考音频语言
VIVY_GSV_PROMPT_LANG=ja

# 语速
VIVY_GSV_SPEED_FACTOR=1.0

# 请求超时（秒）
VIVY_GSV_TIMEOUT=120

# 失败时是否退回系统音色
VIVY_TTS_FALLBACK_SYSTEM=false

# =========================
# GPT-SoVITS 真流式播放
# =========================
VIVY_GSV_TRUE_STREAMING=true
VIVY_GSV_STREAMING_MODE=3
VIVY_GSV_FRAGMENT_INTERVAL=0.05
VIVY_GSV_MIN_CHUNK_LENGTH=8
VIVY_GSV_OVERLAP_LENGTH=2

# 桌宠空闲收起时间
VIVY_IDLE_TIMEOUT=30
