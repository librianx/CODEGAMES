# ---------- 大模型（OpenAI 兼容 /chat/completions）----------
# VIVY 通过 deepseek_client 调「与 OpenAI 同结构的接口」。变量名虽带 DEEPSEEK，
# 只要把 BASE_URL + MODEL + API_KEY 换成你的服务商即可。
#
# 官方 Cursor API（https://api.cursor.com）是团队管理、分析、云 Agent 等 REST，
# 不提供桌宠这种「流式对话」接口，不能直接把 DEEPSEEK_BASE_URL 换成 api.cursor.com。
# 若你想用和 Cursor 里类似的模型，请使用该模型厂商的 API（或 OpenAI 兼容中转），例如：
#
# OpenAI 示例：
# DEEPSEEK_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=sk-...
#
# DeepSeek（默认）：
DEEPSEEK_API_KEY=YOUR_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: vision model for image understanding (OpenAI-compatible multimodal chat/completions)
# If you want Vivy to "see" images, set this to a model that supports vision.
# Example (OpenAI): gpt-4o-mini
# Example (DeepSeek or other providers): choose their vision-capable model name
# DEEPSEEK_VISION_MODEL=deepseek-vl

# Max image bytes accepted by backend/UI (default 3,000,000)
# VIVY_IMAGE_MAX_BYTES=3000000

# Flask
FLASK_PORT=5000

# Optional: enable LLM-based memory summary
LLM_SUMMARY=true

# 桌宠空闲收起时间
VIVY_IDLE_TIMEOUT=30

# 天气系统
# 用户没有在本轮消息里指定城市时，会优先使用右键菜单“设置当前位置”保存的城市；
# 如果没有手动设置，再使用这里的默认城市。
# VIVY_DEFAULT_CITY=上海
VIVY_DEFAULT_COUNTRY=CN

# 是否允许通过 IP 粗略判断城市。建议默认关闭，由用户在右键菜单里开启。
VIVY_AUTO_LOCATION=false
VIVY_LOCATION_PROVIDER=ipapi
VIVY_LOCATION_CACHE_TTL=3600
VIVY_GEOCODE_CACHE_TTL=86400
VIVY_WEATHER_CACHE_TTL=600

# 每日问候默认开启；也可以在桌宠右键菜单里开启/关闭。
VIVY_WEATHER_GREETING_ENABLED=true

## Cursor Cloud Agents
# 已移除桌宠内置的 Cursor 云 Agent 功能，因此不再需要相关配置项。
